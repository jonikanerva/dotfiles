[core]
	autocrlf = input
	quotepath = false
	excludesfile = ~/.gitignore
	editor = code --wait
	preloadindex = true
	precomposeunicode = true
	pager = delta
[user]
	name = Joni Kanerva
	email = jhonny@jhonny.org
	signingkey = 0E51DDBF00087D5509E59CEDCF7250EFB1D491E9
[github]
	user = jonikanerva
[color]
	branch = auto
	diff = auto
	interactive = auto
	status = auto
	ui = auto
[alias]
	s = status
	b = branch
	f = fetch
	d = diff
	co = checkout
	l = log --name-status
	pb = remote prune origin
	nm = branch -r --no-merged
	mm = branch -r --merged
	ri = rebase --interactive main
[interactive]
	diffFilter = delta --color-only
[push]
	default = simple
[merge]
	conflictStyle = zdiff3
[mergetool]
	keepBackup = false
	prompt = false
[credential]
	helper = osxkeychain
[commit]
	gpgsign = true
[url "git@github.com:"]
	insteadOf = https://github.com/
[pull]
	ff = only
[init]
	defaultBranch = main
[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true